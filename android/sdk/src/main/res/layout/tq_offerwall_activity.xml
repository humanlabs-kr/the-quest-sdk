<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/tq_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/tq_background"
    android:orientation="vertical">

    <!-- Native header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/tq_header_background"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageButton
            android:id="@+id/tq_close"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginStart="4dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/tq_close_content_description"
            android:scaleType="center"
            android:src="@drawable/tq_ic_close" />

        <TextView
            android:id="@+id/tq_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="52dp"
            android:ellipsize="end"
            android:gravity="center"
            android:maxLines="1"
            android:text="@string/tq_title"
            android:textColor="@color/tq_text"
            android:textSize="17sp"
            android:textStyle="bold" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/tq_header_border" />

    <!-- WebView (added programmatically) + overlays -->
    <FrameLayout
        android:id="@+id/tq_webview_container"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <ProgressBar
            android:id="@+id/tq_progress"
            style="?android:attr/progressBarStyleLarge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:visibility="gone" />

        <LinearLayout
            android:id="@+id/tq_error"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="24dp"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:gravity="center"
                android:text="@string/tq_error_message"
                android:textColor="@color/tq_text"
                android:textSize="16sp" />

            <Button
                android:id="@+id/tq_retry"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/tq_retry" />
        </LinearLayout>
    </FrameLayout>

</LinearLayout>
