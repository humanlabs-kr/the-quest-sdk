<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/tq_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/tq_background"
    android:orientation="vertical">

    <!-- No native header: the web renders its own header (with a bridge-wired close button).
         WebView (added programmatically) + overlays fill the whole screen. -->
    <FrameLayout
        android:id="@+id/tq_webview_container"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <ProgressBar
            android:id="@+id/tq_progress"
            style="?android:attr/progressBarStyleLarge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:visibility="gone" />

        <LinearLayout
            android:id="@+id/tq_error"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="24dp"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:gravity="center"
                android:text="@string/tq_error_message"
                android:textColor="@color/tq_text"
                android:textSize="16sp" />

            <Button
                android:id="@+id/tq_retry"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/tq_retry" />

            <!-- With no native header, this is the only close affordance if the web
                 (which otherwise renders the close button) fails to load. -->
            <Button
                android:id="@+id/tq_error_close"
                style="?android:attr/borderlessButtonStyle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/tq_close_content_description" />
        </LinearLayout>
    </FrameLayout>

</LinearLayout>
